#, c-format
msgid "Window size changed, now snowing in in %#lx: %s %d+%d %dx%d\n"
msgstr "Zmieniono rozmiar okna, teraz pada śnieg w %#lx: %s %d+%d %dx%d\n"

#: src/main.c:1711
#, c-format

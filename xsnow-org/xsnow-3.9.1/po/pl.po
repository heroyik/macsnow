#, c-format
msgid "Using window 'Desktop'.\n"
msgstr "Korzystanie z okna „Pulpit”.\n"

#: src/main.c:879
#, c-format
msgid "Using root window\n"
msgstr "Korzystanie z okna głównego \n"

#: src/main.c:970
#, c-format
msgid "Snowing in %#lx: %s size: %dx%d\n"
msgstr "Śnieg w %#lx: %s rozmiar: %dx%d\n"

#: src/main.c:1003
#, c-format
msgid "Using double buffer: %#lx %dx%d\n"
msgstr "Używanie podwójnego bufora: %#lx %dx%d\n"

#: src/main.c:1012
#, c-format
msgid "NOT using double buffering:"
msgstr "NIE używając podwójnego buforowania:"

#: src/main.c:1014
#, c-format
msgid " because double buffering is not available on this system\n"
msgstr " ponieważ podwójne buforowanie nie jest dostępne w tym systemie\n"

#: src/main.c:1016
#, c-format
msgid " on your request.\n"
msgstr " na Twoją prośbę.\n"

#: src/main.c:1017
#, c-format
msgid "NOTE: expect some flicker.\n"
msgstr "UWAGA: spodziewaj się migotania.\n"

#: src/main.c:1260
msgid "Restart due to change of screen or language settings ...\n"
msgstr "Uruchom ponownie z powodu zmiany ustawień ekranu lub języka ...\n"


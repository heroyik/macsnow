msgid "Restart due to change of display settings...\n"
msgstr "Uruchom ponownie z powodu zmiany ustawień wyświetlania...\n"

#: src/main.c:1381
msgid "Wayland (Expect some slugginess)"
msgstr "Wayland (spodziewaj się spowolnienia)"

#: src/main.c:1385
msgid "Probably X11"
msgstr "Prawdopodobnie X11"

#: src/main.c:1387
#, c-format
msgid "%s. Snow window: %#lx"
msgstr "%s. Okno śniegu: %#lx"


#, c-format
msgid "Using transparent window: %dx%d\n"
msgstr "Używanie przezroczystego okna: %dx%d\n"

#: src/main.c:840
#, c-format
msgid "The transparent snow-window is probably not click-through, alas..\n"
msgstr ""
"Przezroczyste okienko ze śniegiem prawdopodobnie nie jest widoczne, "

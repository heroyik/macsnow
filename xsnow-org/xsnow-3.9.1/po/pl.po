#, c-format
msgid "NOTE: xsnow will probably run, but some glitches are to be expected.\n"
msgstr ""
"UWAGA: xsnow prawdopodobnie będzie działać, ale należy spodziewać się "
"pewnych usterek. \n"

#: src/main.c:867
#, c-format
msgid "LXDE session found, using window 'pcmanfm'.\n"
msgstr "Znaleziono sesję LXDE przy użyciu okna „pcmanfm”.\n"


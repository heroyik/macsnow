msgstr "Перезапуск через зміну налаштувань екрана або мови ...\n"

#: src/main.c:1275
msgid "Restart due to change of display settings...\n"
msgstr "Перезапуск через зміну налаштувань дисплея...\n"

#: src/main.c:1381
msgid "Wayland (Expect some slugginess)"
msgstr "Wayland (Очікуйте деяку повільність)"


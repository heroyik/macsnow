#, c-format
msgid "The transparent snow-window is probably not click-through, alas..\n"
msgstr "Το διαφανές χιόνι-παράθυρο μάλλον δεν είναι κλικ, δυστυχώς..\n"

#: src/main.c:848
#, c-format
msgid "Cannot create transparent window\n"
msgstr "Δεν είναι δυνατή η δημιουργία διαφανούς παραθύρου \n"

#: src/main.c:850
#, c-format
msgid "NOTE: xsnow will probably run, but some glitches are to be expected.\n"
msgstr ""
"ΣΗΜΕΙΩΣΗ: xsnow πιθανότατα θα εκτελεστεί, αλλά αναμένονται κάποιες "
"δυσλειτουργίες.\n"

#: src/main.c:867
#, c-format
msgid "LXDE session found, using window 'pcmanfm'.\n"
msgstr ""
"Βρέθηκε περίοδος λειτουργίας LXDE, χρησιμοποιώντας το παράθυρο 'pcmanfm'.\n"

#: src/main.c:875
#, c-format
msgid "Using window 'Desktop'.\n"
msgstr "Χρήση παραθύρου 'Desktop'.\n"

#: src/main.c:879
#, c-format
msgid "Using root window\n"
msgstr "Χρήση ριζικού παραθύρου \n"

#: src/main.c:970
#, c-format
msgid "Snowing in %#lx: %s size: %dx%d\n"
msgstr "Χιονίζει σε %#lx: %s μέγεθος: %dx%d\n"

#: src/main.c:1003
#, c-format
msgid "Using double buffer: %#lx %dx%d\n"
msgstr "Χρήση διπλού buffer: %#lx %dx%d\n"

#: src/main.c:1012
#, c-format
msgid "NOT using double buffering:"
msgstr "ΔΕΝ χρησιμοποιεί διπλό buffering:"

#: src/main.c:1014
#, c-format
msgid " because double buffering is not available on this system\n"
msgstr ""
" επειδή η διπλή προσωρινή αποθήκευση δεν είναι διαθέσιμη σε αυτό το "
"σύστημα \n"

#: src/main.c:1016
#, c-format
msgid " on your request.\n"
msgstr " κατόπιν αιτήματός σας. \n"

#: src/main.c:1017
#, c-format
msgid "NOTE: expect some flicker.\n"
msgstr "ΣΗΜΕΙΩΣΗ: περιμένετε κάποιο τρεμόπαιγμα.\n"

#: src/main.c:1260
msgid "Restart due to change of screen or language settings ...\n"
msgstr "Επανεκκίνηση λόγω αλλαγής ρυθμίσεων οθόνης ή γλώσσας ...\n"

#: src/main.c:1275
msgid "Restart due to change of display settings...\n"
msgstr "Επανεκκίνηση λόγω αλλαγής των ρυθμίσεων οθόνης...\n"

#: src/main.c:1381
msgid "Wayland (Expect some slugginess)"
msgstr "Wayland (Περιμένετε κάποια νωθρότητα)"

#: src/main.c:1385
msgid "Probably X11"
msgstr "Μάλλον X11"

#: src/main.c:1387
#, c-format
msgid "%s. Snow window: %#lx"
msgstr "%s. Παράθυρο χιονιού: %#lx"

#: src/main.c:1436
#, c-format
msgid "More than %d errors, I quit!"
msgstr "Περισσότερα από %d σφάλματα, τα παράτησα!"

#: src/main.c:1631
#, c-format
msgid "Window size changed, now snowing in in %#lx: %s %d+%d %dx%d\n"
msgstr ""
"Το μέγεθος του παραθύρου άλλαξε, τώρα χιονίζει σε %#lx: %s %d+%d %dx%d\n"

#: src/main.c:1711
#, c-format
msgid "Halting because of flag %s\n"
msgstr "Παύση λόγω σημαίας %s\n"

#: src/selfrep.c:35
#, c-format
msgid "Not sending tar file to terminal.\n"
msgstr "Δεν αποστέλλεται το αρχείο tar στο τερματικό.\n"

#: src/selfrep.c:36
#, c-format
msgid "Try redirecting to a file (e.g: %s,\n"
msgstr "Δοκιμάστε να ανακατευθυνθείτε σε ένα αρχείο (π.χ.: %s,\n"

#: src/selfrep.c:37
#, c-format
msgid "or use a %s"
msgstr "ή χρησιμοποιήστε ένα %s"

#: src/selfrep.c:43
msgid "Problems encountered during production of the tar ball.\n"
msgstr "Προβλήματα που προέκυψαν κατά την παραγωγή της μπάλας πίσσας.\n"

#: src/selfrep.c:48
#, c-format
msgid "Self replication is not compiled in.\n"
msgstr "Η αυτοανατύπωση δεν έχει μεταγλωττιστεί στο.\n"


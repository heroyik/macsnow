#, c-format
msgid "NOTE: expect some flicker.\n"
msgstr "MEGJEGYZÉS: némi vibrálásra számítson. \n"

#: src/main.c:1260
msgid "Restart due to change of screen or language settings ...\n"
msgstr ""
"Újraindítás a képernyő vagy a nyelvi beállítások megváltozása miatt...\n"

#: src/main.c:1275
msgid "Restart due to change of display settings...\n"
msgstr "Újraindítás a megjelenítési beállítások megváltozása miatt...\n"


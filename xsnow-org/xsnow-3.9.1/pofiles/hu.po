#, c-format
msgid "Snowing in %#lx: %s size: %dx%d\n"
msgstr "Havazik %#lx: %s méret: %dx%d\n"

#: src/main.c:1003
#, c-format
msgid "Using double buffer: %#lx %dx%d\n"
msgstr "Dupla puffer használata: %#lx %dx%d\n"

#: src/main.c:1012
#, c-format
msgid "NOT using double buffering:"
msgstr "NEM használ kettős pufferelést:"

